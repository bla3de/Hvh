-- Stars (Dramatic Twinkling)
local stars = {}
for i = 1, 50 do
	local star = Instance.new("TextLabel")
	star.Size = UDim2.new(0, math.random(4,7), 0, math.random(4,7))
	star.Position = UDim2.new(math.random(), 0, math.random(), 0)
	star.BackgroundTransparency = 1
	star.Text = "★"
	star.TextColor3 = Color3.fromRGB(255, 255, 255)
	star.TextScaled = true
	star.Font = Enum.Font.GothamBlack
	star.TextTransparency = math.random(10,40)/100
	star.Parent = Background
	table.insert(stars, star)
end

-- Dramatic star twinkling
RunService.Heartbeat:Connect(function()
	for _, star in ipairs(stars) do
		if math.random() < 0.045 then
			local target = math.random(5, 35) / 100
			TweenService:Create(star, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {TextTransparency = target}):Play()
			
			task.delay(0.2 + math.random()*0.4, function()
				if star and star.Parent then
					TweenService:Create(star, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {TextTransparency = 0}):Play()
				end
			end)
		end
	end
end)

