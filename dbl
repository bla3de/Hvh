-- Dynamic Status Label
local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(0.6, 0, 0.05, 0)
StatusLabel.Position = UDim2.new(0.2, 0, 0.63, 0)
StatusLabel.BackgroundTransparency = 1
StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
StatusLabel.Font = Enum.Font.GothamSemibold
StatusLabel.TextSize = 18
StatusLabel.TextStrokeTransparency = 0.6
StatusLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
StatusLabel.Parent = Background

local statuses = {
	"Connecting to server...",
	"Initializing security bypass...",
	"Bypassing Anticheat Layer 1...",
	"Decrypting game protocols...",
	"Injecting core scripts...",
	"Verifying server integrity...",
	"Bypassing Anticheat Layer 2...",
	"Loading assets & modules...",
	"Final security handshake...",
	"Almost there..."
}
local statusIndex = 1

-- === ULTRA SLOW LOADING ===
local progress = 0
local startTime = tick()
local totalDuration = 240  -- 4 minutes (very slow)

while progress < 100 do
	local elapsed = tick() - startTime
	progress = math.clamp((elapsed / totalDuration) * 100, 0, 99.7)
	
	LoadingBar.Size = UDim2.new(progress/100, 0, 1, 0)
	PercentLabel.Text = math.floor(progress) .. "%"
	
	-- Smooth glow movement
	local glowX = math.clamp((progress/100) - 0.07, 0, 0.93)
	GlowBar.Position = UDim2.new(glowX, 0, -0.1, 0)
	
	-- Dynamic glowing color (slow pulse)
	local t = tick() * 4
	GlowBar.BackgroundColor3 = Color3.fromRGB(90, math.clamp(155 + math.sin(t)*60, 140, 230), 255)
	
	-- Very gentle title breathing
	Title.Position = UDim2.new(0.2, math.sin(tick() * 2.8) * 1.8, 0.35, 0)
	
	-- Very slow status cycling
	if (tick() - (startTime + (statusIndex-1)*12)) > 12 then
		statusIndex = (statusIndex % #statuses) + 1
		StatusLabel.Text = statuses[statusIndex]
	end
	
	task.wait(0.045) -- Slightly slower update rate for ultra slow feel
end

-- Finish
PercentLabel.Text = "100%"
StatusLabel.Text = "Successfully Bypassed!"
task.wait(9000)

-- Completion Sound
local successSound = Instance.new("Sound")
successSound.SoundId = "rbxassetid://131057809"
